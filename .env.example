# Chave da API da Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Token do GitHub para clonar o repositório dentro da sessão.
# Fine-grained PAT com "Contents: Read and write" (e Pull requests: Read and write para abrir PRs).
GITHUB_TOKEN=ghp_...

# Repositório alvo da squad (a squad "se conecta" aqui)
TARGET_REPO_URL=https://github.com/sua-org/seu-repo
TARGET_REPO_BRANCH=main

# Preenchido automaticamente por `npm run setup` — IDs do environment e dos agentes.
# Não edite à mão; se quiser recriar tudo, apague o arquivo .squad-ids.json.
