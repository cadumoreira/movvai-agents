# ─────────────────────────────────────────────────────────────────────────────
# MODELOS / PROVEDORES  (arquitetura agnóstica de provedor)
# ─────────────────────────────────────────────────────────────────────────────
# Chaves dos provedores que você for usar. Preencha pelo menos uma.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# (Opcional) Gateway OpenAI-compatible (ex.: LiteLLM self-hosted).
# Se definido, TODOS os modelos passam por aqui (roteamento/caching/custo centralizados).
# Deixe vazio para chamar os provedores diretamente.
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=

# Modelo do agente PM, no formato "provedor:modelo".
# provedores: anthropic | openai | google | gateway
# Refinamento não precisa do topo — default em Sonnet (bom custo-benefício).
PM_MODEL=anthropic:claude-sonnet-4-6

# Modelo do agente Dev — escrever código exige o topo de capacidade.
DEV_MODEL=anthropic:claude-opus-4-8

# Modelo do agente QA (revisão de PR).
QA_MODEL=anthropic:claude-sonnet-4-6

# Modelo do squad de marketing (Malu/Head + Caio/Sofia/Leo/Nina). Copy exige bom texto.
MARKETING_MODEL=anthropic:claude-sonnet-4-6

# Modelo barato para tarefas simples (roteamento de custo por tier).
CHEAP_MODEL=anthropic:claude-haiku-4-5

# Orçamento de tokens por execução de agente (guarda de custo). 0 = sem limite.
AGENT_TOKEN_BUDGET=400000

# Pasta das skills (playbooks em Markdown que os agentes carregam sob demanda).
SKILLS_DIR=skills

# (Opcional) Fila durável. Se definido, usa BullMQ/Redis; senão, fila em processo.
REDIS_URL=

# Porta do painel web (ver atividade e aprovar fora do Slack). Default 3000.
DASHBOARD_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# CONTROLE DE ACESSO (RBAC)
# ─────────────────────────────────────────────────────────────────────────────
# Quem pode aprovar via Slack (user IDs, separados por vírgula). Vazio = qualquer um.
APPROVER_SLACK_IDS=
# Token exigido para aprovar pelo painel (Bearer). Vazio = aberto (local).
DASHBOARD_TOKEN=
# Identificador da organização (tagueia auditoria e billing; fundação para multi-org).
ORG_ID=default

# (Opcional) Caminho do log de billing (consumo por org, JSONL). Default billing.log.
BILLING_LOG_PATH=billing.log

# (Opcional) Conselho multi-modelo: lista separada por vírgula de "provedor:modelo".
# Com >=2 modelos, QA e Tech Lead podem convocar um parecer colegiado em decisões de alto valor.
# Ex.: anthropic:claude-opus-4-8,openai:gpt-5,google:gemini-3-pro
COUNCIL_MODELS=
COUNCIL_SYNTH_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILIDADE (OpenTelemetry → Langfuse). Opcional; vazio = tracing desligado.
# ─────────────────────────────────────────────────────────────────────────────
# Opção A — Langfuse:
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
# Opção B — qualquer backend OTLP (Phoenix, Grafana, etc.):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─────────────────────────────────────────────────────────────────────────────
# E2B  (sandbox efêmero por tarefa onde o Dev clona/edita/roda testes)
# ─────────────────────────────────────────────────────────────────────────────
E2B_API_KEY=

# (Opcional) Modelos locais via Ollama (API OpenAI-compatible). Use "ollama:llama3.1".
OLLAMA_BASE_URL=http://localhost:11434/v1

# (Opcional) Manus — agente externo de tarefas assíncronas (o PM pode delegar tarefas abertas).
MANUS_API_KEY=
MANUS_BASE_URL=https://api.manus.ai/v1

# ─────────────────────────────────────────────────────────────────────────────
# SLACK  (a UI primária — onde você conversa com o time)
# ─────────────────────────────────────────────────────────────────────────────
# App do Slack em modo Socket Mode (mais simples para começar, sem expor URL pública).
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
# Canal para onde o time reporta quando o trabalho chega por webhook (ex.: C0123ABC).
SLACK_DEFAULT_CHANNEL=

# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOKS DE ENTRADA  (issue dispara o time automaticamente)
# ─────────────────────────────────────────────────────────────────────────────
# Aponte o webhook do GitHub/Linear para http(s)://<host>:DASHBOARD_PORT/webhooks/{github,linear}
GITHUB_WEBHOOK_SECRET=
LINEAR_WEBHOOK_SECRET=
# Label que aciona o time (na issue do GitHub/Linear).
AGENT_TRIGGER_LABEL=agent

# ─────────────────────────────────────────────────────────────────────────────
# LINEAR  (gestão de demanda — onde o PM escreve os tickets)
# ─────────────────────────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_...
# (Opcional) Time padrão onde criar issues. Se vazio, usa o primeiro time da conta.
LINEAR_TEAM_KEY=

# (Opcional) Jira como alternativa/adicional ao Linear. Preencha os quatro para ativar.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# NOTION  (board do squad de MARKETING — briefs, calendário, rascunhos)
# ─────────────────────────────────────────────────────────────────────────────
# Integração interna em notion.so/my-integrations; compartilhe o database/página com ela.
NOTION_API_KEY=
# Onde as páginas nascem (preencha UM dos dois):
# database (um item por brief — recomendado p/ calendário editorial)…
NOTION_DATABASE_ID=
# …ou uma página-mãe (os briefs viram subpáginas dela).
NOTION_PARENT_PAGE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB  (read no MVP — PM investiga o repositório)
# ─────────────────────────────────────────────────────────────────────────────
# Fine-grained PAT. Fase 1 (Dev abre PR) exige Contents:read+write e Pull requests:read+write.
# (Hardening Fase 3: mover para credential proxy — o token não deve ficar no sandbox.)
GITHUB_TOKEN=
# Repositório padrão para investigar, no formato owner/repo.
GITHUB_DEFAULT_REPO=
