# ─────────────────────────────────────────────────────────────────────────────
# MODELOS / PROVEDORES  (arquitetura agnóstica de provedor)
# ─────────────────────────────────────────────────────────────────────────────
# Chaves dos provedores que você for usar. Preencha pelo menos uma.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# (Opcional) Gateway OpenAI-compatible (ex.: LiteLLM self-hosted).
# Se definido, TODOS os modelos passam por aqui (roteamento/caching/custo centralizados).
# Deixe vazio para chamar os provedores diretamente.
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=

# Modelo do agente PM, no formato "provedor:modelo".
# provedores: anthropic | openai | google | gateway
# Refinamento não precisa do topo — default em Sonnet (bom custo-benefício).
PM_MODEL=anthropic:claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────────────────────
# SLACK  (a UI primária — onde você conversa com o time)
# ─────────────────────────────────────────────────────────────────────────────
# App do Slack em modo Socket Mode (mais simples para começar, sem expor URL pública).
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# LINEAR  (gestão de demanda — onde o PM escreve os tickets)
# ─────────────────────────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_...
# (Opcional) Time padrão onde criar issues. Se vazio, usa o primeiro time da conta.
LINEAR_TEAM_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB  (read no MVP — PM investiga o repositório)
# ─────────────────────────────────────────────────────────────────────────────
# Fine-grained PAT com Contents:read e Metadata:read (Fase 0 é só leitura).
GITHUB_TOKEN=
# Repositório padrão para investigar, no formato owner/repo.
GITHUB_DEFAULT_REPO=
